
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int    @id @default(autoincrement())
  fullName     String
  email        String @unique
  passwordHash String
  role         String
  jobApplications JobApplication[]
}

model JobRole {
  jobRoleId    Int           @id @default(autoincrement())
  roleName     String
  location     String
  capabilityId Int
  bandId       Int
  closingDate  DateTime
  status       String
  description  String        @default("")
  responsibilities String[]  @default([])
  sharepointUrl String       @default("")
  numberOfOpenPositions Int  @default(0)
  capability   Capability    @relation(fields: [capabilityId], references: [capabilityId])
  band         Band          @relation(fields: [bandId], references: [nameId])
  jobApplications JobApplication[]
}

model JobApplication {
  applicationId Int      @id @default(autoincrement())
  jobRoleId     Int
  userId        Int
  cvUrl         String
  status        String
  createdAt     DateTime @default(now())
  jobRole       JobRole  @relation(fields: [jobRoleId], references: [jobRoleId])
  user          User     @relation(fields: [userId], references: [id])

  @@unique([jobRoleId, userId])
}

model Capability {
  capabilityId   Int       @id @default(autoincrement())
  capabilityName String
  jobRoles       JobRole[]
}

model Band {
  nameId   Int       @id @default(autoincrement())
  bandName String
  jobRoles JobRole[]
}
