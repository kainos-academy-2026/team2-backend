
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobRoleStatus {
  OPEN
  CLOSED
}

model JobRole {
  jobRoleId    Int           @id @default(autoincrement())
  roleName     String
  location     String
  capabilityId Int
  bandId       Int
  closingDate  DateTime
  status       JobRoleStatus @default(OPEN)
  capability   Capability    @relation(fields: [capabilityId], references: [capabilityId])
  band         Band          @relation(fields: [bandId], references: [nameId])

  @@map("job-roles")
}

model Capability {
  capabilityId   Int       @id @default(autoincrement())
  capabilityName String
  jobRoles       JobRole[]

  @@map("capability")
}

model Band {
  nameId   Int       @id @default(autoincrement())
  bandName String
  jobRoles JobRole[]

  @@map("band")
}
